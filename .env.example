# ─────────────────────────────────────────────
#  LINE OA × WordPress RAG × Gemini + Supabase
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ─────────────────────────────────────────────

# LINE Messaging API
# วิธีหา: developers.line.biz → channel → Basic settings / Messaging API
LINE_CHANNEL_ACCESS_TOKEN=ใส่ channel access token ที่นี่
LINE_CHANNEL_SECRET=ใส่ channel secret ที่นี่

# Google Gemini
# วิธีหา: aistudio.google.com/app/apikey → Create API Key
GEMINI_API_KEY=ใส่ gemini api key ที่นี่

# WordPress Site
# ใส่ URL ของ WordPress คุณ (ไม่ต้องมี / ท้าย)
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_PER_PAGE=100
# ถ้า WordPress เป็น private ใส่แบบนี้: username:application_password
# WORDPRESS_AUTH=myuser:xxxx xxxx xxxx xxxx

# Supabase
# วิธีหา: supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_TABLE=article_chunks

# Server
PORT=3000

# RAG
RAG_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100
SIMILARITY_THRESHOLD=0.7

# Bot Personality
BOT_NAME=AI Assistant

# Security — ใส่ random string เพื่อป้องกัน /sync endpoint
SYNC_SECRET=change-this-to-random-string
